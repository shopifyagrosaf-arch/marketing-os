# ---- Shared ----
NODE_ENV=development

# ---- Database (apps/api) ----
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/agrosaf_marketing_os?schema=public"

# ---- Redis / Queue (apps/api) ----
REDIS_URL="redis://localhost:6379"

# ---- Auth (shared secret between apps/web Auth.js and apps/api JWT verification) ----
AUTH_SECRET="replace-with-a-long-random-string"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_MICROSOFT_ENTRA_ID=""
AUTH_MICROSOFT_ENTRA_SECRET=""
AUTH_MICROSOFT_ENTRA_TENANT_ID=""

# ---- apps/web ----
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXTAUTH_URL="http://localhost:3000"

# ---- apps/api ----
API_PORT=3001
CORS_ORIGIN="http://localhost:3000"

# ---- Object storage (stubbed until Phase 2 integration adapters are wired) ----
STORAGE_PROVIDER="r2" # r2 | s3
STORAGE_BUCKET=""
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""
STORAGE_ENDPOINT=""

# ---- Seed script only (apps/api/prisma/seed.ts) — not read at runtime ----
# Required: identifies who becomes the initial Super Admin. Intentionally has
# no default so a real Super Admin identity is never hardcoded.
SEED_SUPER_ADMIN_EMAIL=""
