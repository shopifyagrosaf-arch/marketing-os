// Agrosaf Marketing OS — schema
// Sprint 1: Organization/Brand hierarchy, Users, RBAC (Role/Permission/BrandAccess), Audit log.
// Sprint 3B: ContentRequest — intake + workflow engine skeleton (status enum + transitions).
// Publishing/analytics models and the rest of the approval pipeline are added in later sprints per the roadmap.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// A company using the platform. Single row today (Agrosaf Group);
/// modeled explicitly so the future multi-company SaaS direction
/// (SRS v2 A11 / FR23) does not require a schema migration later.
model Organization {
  id        String   @id @default(cuid())
  name      String
  planTier  String   @default("internal") // internal | saas-starter | saas-pro (future)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  brands Brand[]
  users  User[]
  roles  Role[] // custom roles scoped to this organization (see Role's doc comment)

  @@map("organizations")
}

/// One of the four Agrosaf divisions today; a tenant-scoping unit for
/// almost all content/campaign/asset data added in later sprints.
model Brand {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  slug           String   @unique
  localeDefault  String   @default("en")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  brandAccess     BrandAccess[]
  contentRequests ContentRequest[]

  @@index([organizationId])
  @@map("brands")
}

/// A person who can log in. Identity comes from Auth.js (SSO); this
/// row is created/linked on first login (see AuthService.validateOrCreateUser).
model User {
  id             String     @id @default(cuid())
  organizationId String
  email          String     @unique
  name           String
  authProviderId String? // subject/id from the SSO provider
  status         UserStatus @default(ACTIVE)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization     Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  brandAccess      BrandAccess[]
  requestedContent ContentRequest[]

  @@index([organizationId])
  @@map("users")
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  EXPIRED // used for time-boxed External Agency/Freelancer accounts (SRS v2 1.4)
}

/// A named role. Seeded with the 14 roles from the SRS (organizationId
/// null — global/system roles available to every organization); Super
/// Admin can create additional custom roles at runtime (FR: extensible
/// RBAC), which are scoped to the creating organizationId so a future
/// second organization (see Organization's doc comment) can never see,
/// assign, edit, or delete another organization's custom roles. Name stays
/// globally unique for simplicity (not per-organization) — acceptable
/// since only one organization exists today; revisit if/when a second
/// organization actually onboards.
model Role {
  id             String  @id @default(cuid())
  name           String  @unique
  isCustom       Boolean @default(false)
  isOrgWide      Boolean @default(false) // true for Super Admin / Marketing Head (not brand-scoped)
  organizationId String? // null = global/system role; set = custom role scoped to this org

  organization Organization?    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  permissions  RolePermission[]
  brandAccess  BrandAccess[]

  @@index([organizationId])
  @@map("roles")
}

/// A single grantable action, e.g. "content:approve", "compliance:review".
/// Kept as a flat action string rather than a fixed enum so Super Admin
/// can compose custom roles without a code change.
model Permission {
  id          String  @id @default(cuid())
  action      String  @unique
  description String?

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

/// Join of User x Brand x Role. This is the core of the "one user can
/// switch between brands without logging out" requirement: a user's
/// available brands and their role in each are just rows here.
model BrandAccess {
  id      String @id @default(cuid())
  userId  String
  brandId String
  roleId  String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)
  role  Role  @relation(fields: [roleId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())

  @@unique([userId, brandId, roleId])
  @@index([userId])
  @@index([brandId])
  @@map("brand_access")
}

/// Generic audit trail. Populated by an interceptor for RBAC-sensitive
/// mutations in Sprint 1; content/approval actions are added to this
/// same table in later sprints rather than a parallel log.
model AuditLog {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  actorId    String?
  action     String
  before     Json?
  after      Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@map("audit_logs")
}

/// Sprint 3B: intake + workflow-engine skeleton (roadmap Sprint 3B scope is
/// deliberately just "status enum + transitions" — the 10-step approval
/// pipeline's later stages (Brand Review/Compliance/Design/Marketing Head
/// Approval, Sprints 5-7) extend `ContentRequestStatus` and
/// `CONTENT_REQUEST_TRANSITIONS` rather than introducing a parallel model.
/// `contentType`/`channel` are free-form strings, not fixed enums, matching
/// the existing `Permission.action`/`Role.name` precedent — no confirmed
/// exhaustive taxonomy exists yet, and a string avoids a migration every
/// time one is added.
model ContentRequest {
  id            String               @id @default(cuid())
  brandId       String
  requestedById String
  title         String
  description   String?
  contentType   String
  channel       String?
  status        ContentRequestStatus @default(DRAFT)
  dueDate       DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  brand       Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)
  requestedBy User  @relation(fields: [requestedById], references: [id], onDelete: Restrict)

  @@index([brandId])
  @@index([requestedById])
  @@map("content_requests")
}

enum ContentRequestStatus {
  DRAFT
  SUBMITTED
  CANCELLED
}
